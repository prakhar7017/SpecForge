generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Spec {
  id               String   @id @default(cuid())
  title            String
  inputGoal        String
  inputUsers       String
  inputConstraints String?
  templateType     String
  generatedJson    Json
  createdAt        DateTime @default(now())

  @@index([createdAt])
}
